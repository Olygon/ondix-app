generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  PENDING
  ACTIVE
  BLOCKED
  CANCELED
}

enum AccessLevel {
  OWNER
  ADMIN
  MANAGER
  ANALYST
}

enum AccessProfileTier {
  BASIC
  INTERMEDIATE
  ADVANCED
  MANAGER
  ADMINISTRATOR
}

enum EntityStatus {
  ACTIVE
  INACTIVE
}

enum SubscriptionStatus {
  ACTIVE
  BLOCKED
  PENDING
  CANCELED
  SUSPENDED
}

enum SubscriptionInvoiceStatus {
  PENDING
  OVERDUE
  PAID
  CANCELED
  OPEN
}

enum SubscriptionPaymentMethod {
  PIX
  BANK_SLIP
  CREDIT_CARD
  STRIPE_CHECKOUT
  MANUAL
}

enum SubscriptionPaymentStatus {
  CREATED
  PENDING
  PAID
  FAILED
  CANCELED
  REFUNDED
}

enum GovernmentCertificateStatus {
  NEGATIVE
  POSITIVE
  EXPIRED
}

enum CustomerType {
  INDIVIDUAL
  COMPANY
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum ProvidedServiceStatus {
  ACTIVE
  BLOCKED
}

enum CommercialProposalStatus {
  DRAFT
  SENT
  APPROVED
  CONTRACTED
  REJECTED
  EXPIRED
  INACTIVE
}

enum CommercialProposalPaymentMethod {
  CASH
  INSTALLMENTS
  EXCHANGE
}

enum CustomerRiskLevel {
  NOT_CLASSIFIED
  VERY_LOW
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CustomerRiskAnalysisStatus {
  DRAFT
  IN_REVIEW
  COMPLETED
  REOPENED
}

enum CustomerRiskFinalOpinion {
  APPROVED_WITHOUT_RESTRICTIONS
  APPROVED_WITH_RESTRICTIONS
  APPROVED_REDUCED_LIMIT
  REJECTED
}

enum CustomerRiskHistorySource {
  INTERNAL_REVIEW
  MANUAL_REOPEN
  EXTERNAL_QUERY
  SYSTEM
}

enum CustomerRiskExternalSource {
  SERASA
  CENTRAL_BANK
}

enum CustomerRiskQueryStatus {
  NOT_ENABLED
  PENDING
  COMPLETED
  FAILED
}

enum CustomerRiskEventType {
  ANALYSIS_STARTED
  ANALYSIS_UPDATED
  LIMIT_CHANGED
  PAYMENT_DELAY
  EXTERNAL_RESTRICTION
  MANUAL_NOTE
}

enum CustomerCertificateStatus {
  PENDING_PROCESSING
  PROCESSED
  PENDING_VALIDATION
  VALIDATED
  EXPIRED
  POSITIVE
  DELETED
}

enum CustomerCertificateSituation {
  UNKNOWN
  NEGATIVE
  POSITIVE
  POSITIVE_WITH_NEGATIVE_EFFECTS
}

enum CertificateUploadSource {
  INTERNAL
  EXTERNAL
}

enum CertificateUploadLinkStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum CertificateProcessingStatus {
  PROCESSED
  PENDING_VALIDATION
  FAILED
}

enum CertificateConfidenceLevel {
  LOW
  MEDIUM
  HIGH
}

model Company {
  id                          String                        @id @default(cuid())
  name                        String
  slug                        String                        @unique
  legalName                   String?
  taxId                       String?                       @unique
  stateRegistration           String?
  municipalRegistration       String?
  primaryCnae                 String?
  secondaryCnae               String?
  postalCode                  String?
  street                      String?
  streetNumber                String?
  addressComplement           String?
  district                    String?
  city                        String?
  stateCode                   String?
  phone                       String?
  email                       String?
  managingPartnerName         String?
  logoFileName                String?
  logoMimeType                String?
  logoData                    Bytes?
  digitalCertificateFileName  String?
  digitalCertificateMimeType  String?
  digitalCertificateData      Bytes?
  digitalCertificatePassword  String?
  contractCode                String?                       @unique
  subscriptionPlan            String?
  subscriptionDate            DateTime?
  subscriptionStatus          SubscriptionStatus            @default(ACTIVE)
  responsibleAdminUserId      String?
  lastEditedAt                DateTime                      @default(now())
  lastEditedByUserId          String?
  isActive                    Boolean                       @default(true)
  certificates                GovernmentCertificate[]
  accessProfiles              AccessProfile[]
  customers                   Customer[]
  customerRiskAnalyses        CustomerRiskAnalysis[]
  customerRiskHistories       CustomerRiskAnalysisHistory[]
  customerRiskExternalQueries CustomerRiskExternalQuery[]
  customerRiskEvents          CustomerRiskEvent[]
  customerCertificates        CustomerCertificate[]
  commercialProposals         CommercialProposal[]
  commercialProposalItems     CommercialProposalItem[]
  providedServices            ProvidedService[]
  serviceMunicipalTaxRules    ServiceMunicipalTaxRule[]
  certificateUploadLinks      CertificateUploadLink[]
  certificateProcessingLogs   CertificateProcessingLog[]
  subscriberSubscription      SubscriberSubscription?
  subscriptionInvoices        SubscriptionInvoice[]
  subscriptionPayments        SubscriptionPayment[]
  userCompanies               UserCompany[]
  responsibleAdminUser        User?                         @relation("CompanyResponsibleAdmin", fields: [responsibleAdminUserId], references: [id], onDelete: SetNull)
  lastEditedByUser            User?                         @relation("CompanyLastEditedBy", fields: [lastEditedByUserId], references: [id], onDelete: SetNull)
  createdAt                   DateTime                      @default(now())
  updatedAt                   DateTime                      @updatedAt
}

model SubscriberSubscription {
  id                    String                @id @default(cuid())
  companyId             String                @unique
  code                  String                @unique
  planName              String
  status                SubscriptionStatus    @default(ACTIVE)
  currency              String                @default("BRL")
  nextDueDate           DateTime?
  nextChargeAmount      Decimal?              @db.Decimal(12, 2)
  stripeCustomerId      String?
  stripeSubscriptionId  String?
  stripePriceId         String?
  stripePaymentMethodId String?
  canceledAt            DateTime?
  blockedAt             DateTime?
  suspendedAt           DateTime?
  company               Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoices              SubscriptionInvoice[]
  payments              SubscriptionPayment[]
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([companyId, status])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}

model SubscriptionInvoice {
  id                    String                       @id @default(cuid())
  subscriptionId        String
  companyId             String
  reference             String
  dueDate               DateTime
  amount                Decimal                      @db.Decimal(12, 2)
  currency              String                       @default("BRL")
  status                SubscriptionInvoiceStatus    @default(PENDING)
  paymentMethod         SubscriptionPaymentMethod    @default(PIX)
  paymentUrl            String?
  stripeInvoiceId       String?
  stripePaymentIntentId String?
  stripeCheckoutUrl     String?
  paidAt                DateTime?
  canceledAt            DateTime?
  company               Company                      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subscription          SubscriberSubscription       @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  paymentLinks          SubscriptionPaymentInvoice[]
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt

  @@unique([subscriptionId, reference])
  @@index([companyId, status, dueDate])
  @@index([subscriptionId, status, dueDate])
  @@index([stripeInvoiceId])
}

model SubscriptionPayment {
  id                        String                       @id @default(cuid())
  subscriptionId            String
  companyId                 String
  amount                    Decimal                      @db.Decimal(12, 2)
  currency                  String                       @default("BRL")
  method                    SubscriptionPaymentMethod    @default(STRIPE_CHECKOUT)
  status                    SubscriptionPaymentStatus    @default(CREATED)
  provider                  String                       @default("stripe")
  providerPaymentId         String?
  providerCheckoutSessionId String?
  providerPayload           Json?
  paidAt                    DateTime?
  company                   Company                      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subscription              SubscriberSubscription       @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  invoiceLinks              SubscriptionPaymentInvoice[]
  createdAt                 DateTime                     @default(now())
  updatedAt                 DateTime                     @updatedAt

  @@index([companyId, status])
  @@index([subscriptionId, status])
  @@index([provider, providerPaymentId])
  @@index([providerCheckoutSessionId])
}

model SubscriptionPaymentInvoice {
  paymentId String
  invoiceId String
  amount    Decimal             @db.Decimal(12, 2)
  invoice   SubscriptionInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  payment   SubscriptionPayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  createdAt DateTime            @default(now())

  @@id([paymentId, invoiceId])
  @@index([invoiceId])
}

model User {
  id                            String                        @id @default(cuid())
  fullName                      String
  shortName                     String?
  email                         String                        @unique
  phone                         String?
  jobTitle                      String?
  department                    String?
  photoFileName                 String?
  photoMimeType                 String?
  photoData                     Bytes?
  passwordHash                  String
  provisionalPasswordHash       String?
  provisionalPasswordExpiresAt  DateTime?
  status                        UserStatus                    @default(PENDING)
  mustChangePassword            Boolean                       @default(true)
  acceptedTermsAt               DateTime?
  lastLoginAt                   DateTime?
  lastPasswordChangeAt          DateTime?
  userCompanies                 UserCompany[]
  passwordResetTokens           PasswordResetToken[]
  responsibleCompanies          Company[]                     @relation("CompanyResponsibleAdmin")
  editedCompanies               Company[]                     @relation("CompanyLastEditedBy")
  createdCustomers              Customer[]                    @relation("CustomerCreatedBy")
  updatedCustomers              Customer[]                    @relation("CustomerUpdatedBy")
  customerRiskAnalyses          CustomerRiskAnalysis[]        @relation("CustomerRiskAnalysisAnalyst")
  createdCustomerRiskHistories  CustomerRiskAnalysisHistory[] @relation("CustomerRiskHistoryCreatedBy")
  requestedCustomerRiskQueries  CustomerRiskExternalQuery[]   @relation("CustomerRiskQueryRequestedBy")
  createdCustomerRiskEvents     CustomerRiskEvent[]           @relation("CustomerRiskEventCreatedBy")
  uploadedCustomerCertificates  CustomerCertificate[]         @relation("CustomerCertificateUploadedBy")
  validatedCustomerCertificates CustomerCertificate[]         @relation("CustomerCertificateValidatedBy")
  createdCertificateUploadLinks CertificateUploadLink[]       @relation("CertificateUploadLinkCreatedBy")
  createdProvidedServices        ProvidedService[]             @relation("ProvidedServiceCreatedBy")
  updatedProvidedServices        ProvidedService[]             @relation("ProvidedServiceUpdatedBy")
  approvedCommercialProposals    CommercialProposal[]          @relation("CommercialProposalApprovedBy")
  createdCommercialProposals     CommercialProposal[]          @relation("CommercialProposalCreatedBy")
  updatedCommercialProposals     CommercialProposal[]          @relation("CommercialProposalUpdatedBy")
  createdAccessProfiles         AccessProfile[]               @relation("AccessProfileCreatedBy")
  updatedAccessProfiles         AccessProfile[]               @relation("AccessProfileUpdatedBy")
  createdAt                     DateTime                      @default(now())
  updatedAt                     DateTime                      @updatedAt
}

model Customer {
  id                      String                        @id @default(cuid())
  companyId               String
  code                    Int
  type                    CustomerType                  @default(COMPANY)
  name                    String
  federalDocument         String
  stateDocument           String?
  cityDocument            String?
  email                   String?
  phone                   String?
  whatsapp                String?
  whatsappReminderEnabled Boolean                       @default(false)
  status                  CustomerStatus                @default(ACTIVE)
  postalCode              String?
  street                  String?
  streetNumber            String?
  addressComplement       String?
  neighborhood            String?
  city                    String?
  stateCode               String?
  deletedAt               DateTime?
  createdById             String?
  updatedById             String?
  company                 Company                       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy               User?                         @relation("CustomerCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy               User?                         @relation("CustomerUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  riskAnalyses            CustomerRiskAnalysis[]
  riskAnalysisHistories   CustomerRiskAnalysisHistory[]
  riskExternalQueries     CustomerRiskExternalQuery[]
  riskEvents              CustomerRiskEvent[]
  certificates            CustomerCertificate[]
  certificateUploadLinks  CertificateUploadLink[]
  commercialProposals     CommercialProposal[]
  createdAt               DateTime                      @default(now())
  updatedAt               DateTime                      @updatedAt

  @@unique([companyId, code])
  @@unique([companyId, federalDocument])
  @@index([companyId, status, deletedAt])
  @@index([companyId, type])
  @@index([companyId, name])
}

model ServiceLaw116Code {
  id                   String            @id @default(cuid())
  cTribNac             String            @unique
  description          String            @db.Text
  category             String?
  requiresConstruction Boolean           @default(false)
  requiresEvent        Boolean           @default(false)
  requiresProperty     Boolean           @default(false)
  status               EntityStatus      @default(ACTIVE)
  providedServices     ProvidedService[]
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@index([status])
  @@index([category])
}

model ServiceNbsCode {
  id               String            @id @default(cuid())
  code             String            @unique
  description      String            @db.Text
  category         String?
  status           EntityStatus      @default(ACTIVE)
  providedServices ProvidedService[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([status])
  @@index([category])
}

model MunicipalTaxCode {
  id                   String                    @id @default(cuid())
  municipalityIbgeCode String
  stateCode            String                    @default("")
  cTribMun             String
  description          String                    @db.Text
  defaultIssRate       Decimal                   @default(0) @db.Decimal(7, 4)
  status               EntityStatus              @default(ACTIVE)
  serviceTaxRules      ServiceMunicipalTaxRule[]
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  @@unique([municipalityIbgeCode, cTribMun])
  @@index([municipalityIbgeCode, stateCode, status])
}

model ProvidedService {
  id                        String                    @id @default(cuid())
  companyId                 String
  code                      Int
  name                      String
  description               String                    @db.Text
  serviceLaw116Id           String
  serviceNbsId              String
  costAmount                Decimal                   @default(0) @db.Decimal(12, 2)
  profitMarginPercent       Decimal                   @default(0) @db.Decimal(7, 4)
  taxSimpleNationalPercent  Decimal                   @default(0) @db.Decimal(7, 4)
  taxIcmsPercent            Decimal                   @default(0) @db.Decimal(7, 4)
  taxPisPercent             Decimal                   @default(0) @db.Decimal(7, 4)
  taxCofinsPercent          Decimal                   @default(0) @db.Decimal(7, 4)
  taxIbsPercent             Decimal                   @default(0) @db.Decimal(7, 4)
  taxCbsPercent             Decimal                   @default(0) @db.Decimal(7, 4)
  taxIrpjPercent            Decimal                   @default(0) @db.Decimal(7, 4)
  taxCsllPercent            Decimal                   @default(0) @db.Decimal(7, 4)
  taxCidPercent             Decimal                   @default(0) @db.Decimal(7, 4)
  taxIpiPercent             Decimal                   @default(0) @db.Decimal(7, 4)
  commissionPercent         Decimal                   @default(0) @db.Decimal(7, 4)
  administrativeCostPercent Decimal                   @default(0) @db.Decimal(7, 4)
  priceAmount               Decimal                   @default(0) @db.Decimal(12, 2)
  status                    ProvidedServiceStatus     @default(ACTIVE)
  deletedAt                 DateTime?
  createdById               String?
  updatedById               String?
  company                   Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  serviceLaw116             ServiceLaw116Code         @relation(fields: [serviceLaw116Id], references: [id], onDelete: Restrict)
  serviceNbs                ServiceNbsCode            @relation(fields: [serviceNbsId], references: [id], onDelete: Restrict)
  municipalTaxRules         ServiceMunicipalTaxRule[]
  commercialProposalItems   CommercialProposalItem[]
  createdBy                 User?                     @relation("ProvidedServiceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy                 User?                     @relation("ProvidedServiceUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  @@unique([companyId, code])
  @@index([companyId, status, deletedAt])
  @@index([companyId, name])
  @@index([serviceLaw116Id])
  @@index([serviceNbsId])
}

model CommercialProposal {
  id                   String                            @id @default(cuid())
  companyId            String
  code                 Int
  customerId           String
  issueDate            DateTime
  validUntil           DateTime
  deliveryDeadline     String?
  paymentMethod        CommercialProposalPaymentMethod   @default(CASH)
  downPaymentAmount    Decimal                           @default(0) @db.Decimal(12, 2)
  globalDiscountAmount Decimal                           @default(0) @db.Decimal(12, 2)
  deliveryCostAmount   Decimal                           @default(0) @db.Decimal(12, 2)
  materialCostAmount   Decimal                           @default(0) @db.Decimal(12, 2)
  otherCostAmount      Decimal                           @default(0) @db.Decimal(12, 2)
  subtotalAmount       Decimal                           @default(0) @db.Decimal(12, 2)
  totalDiscountAmount  Decimal                           @default(0) @db.Decimal(12, 2)
  totalAmount          Decimal                           @default(0) @db.Decimal(12, 2)
  status               CommercialProposalStatus          @default(DRAFT)
  notes                String?                           @db.Text
  approvedAt           DateTime?
  approvedById         String?
  rejectedAt           DateTime?
  expiredAt            DateTime?
  contractId           String?
  deletedAt            DateTime?
  createdById          String?
  updatedById          String?
  company              Company                           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer             Customer                          @relation(fields: [customerId], references: [id], onDelete: Restrict)
  approvedBy           User?                             @relation("CommercialProposalApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  createdBy            User?                             @relation("CommercialProposalCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy            User?                             @relation("CommercialProposalUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  items                CommercialProposalItem[]
  createdAt            DateTime                          @default(now())
  updatedAt            DateTime                          @updatedAt

  @@unique([companyId, code])
  @@index([companyId, status, deletedAt])
  @@index([companyId, customerId])
  @@index([contractId])
}

model CommercialProposalItem {
  id                         String             @id @default(cuid())
  companyId                  String
  proposalId                 String
  serviceId                  String
  serviceCodeSnapshot        String
  serviceNameSnapshot        String
  serviceDescriptionSnapshot String             @db.Text
  unitPriceAmount            Decimal            @default(0) @db.Decimal(12, 2)
  quantity                   Decimal            @default(1) @db.Decimal(12, 4)
  lineDiscountAmount         Decimal            @default(0) @db.Decimal(12, 2)
  lineDiscountPercent        Decimal            @default(0) @db.Decimal(7, 4)
  lineSubtotalAmount         Decimal            @default(0) @db.Decimal(12, 2)
  lineTotalAmount            Decimal            @default(0) @db.Decimal(12, 2)
  sortOrder                  Int                @default(0)
  company                    Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  proposal                   CommercialProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  service                    ProvidedService    @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime           @updatedAt

  @@index([companyId, proposalId])
  @@index([serviceId])
}

model ServiceMunicipalTaxRule {
  id                   String           @id @default(cuid())
  companyId            String
  serviceId            String
  municipalityIbgeCode String
  municipalTaxCodeId   String
  issRate              Decimal          @default(0) @db.Decimal(7, 4)
  isDefault            Boolean          @default(false)
  notes                String?          @db.Text
  company              Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  service              ProvidedService  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  municipalTaxCode     MunicipalTaxCode @relation(fields: [municipalTaxCodeId], references: [id], onDelete: Restrict)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@unique([serviceId, municipalityIbgeCode])
  @@index([companyId, municipalityIbgeCode])
  @@index([serviceId, isDefault])
  @@index([municipalTaxCodeId])
}

model CustomerRiskAnalysis {
  id                          String                        @id @default(cuid())
  companyId                   String
  customerId                  String
  internalScore               Int?
  externalScore               Int?
  consolidatedScore           Int?
  riskLevel                   CustomerRiskLevel             @default(NOT_CLASSIFIED)
  recommendedSalesLimit       Decimal?                      @db.Decimal(12, 2)
  approvedSalesLimit          Decimal?                      @db.Decimal(12, 2)
  maxTermDays                 Int?
  requiresDownPayment         Boolean                       @default(false)
  requiresFormalContract      Boolean                       @default(false)
  requiresAdditionalGuarantee Boolean                       @default(false)
  allowsInstallments          Boolean                       @default(true)
  finalOpinion                CustomerRiskFinalOpinion?
  analysisStatus              CustomerRiskAnalysisStatus    @default(DRAFT)
  analystUserId               String?
  analysisDate                DateTime?
  notes                       String?
  latePaymentHistoryScore     Int?
  defaultFrequencyScore       Int?
  financialVolumeScore        Int?
  relationshipTimeScore       Int?
  activeContractScore         Int?
  externalRestrictionScore    Int?
  riskConcentrationScore      Int?
  commercialDependencyScore   Int?
  externalScoreCriterion      Int?
  manualAnalystRating         String?
  company                     Company                       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer                    Customer                      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  analystUser                 User?                         @relation("CustomerRiskAnalysisAnalyst", fields: [analystUserId], references: [id], onDelete: SetNull)
  histories                   CustomerRiskAnalysisHistory[]
  externalQueries             CustomerRiskExternalQuery[]
  events                      CustomerRiskEvent[]
  createdAt                   DateTime                      @default(now())
  updatedAt                   DateTime                      @updatedAt

  @@index([companyId, customerId, analysisStatus])
  @@index([customerId, updatedAt])
}

model CustomerRiskAnalysisHistory {
  id                 String                    @id @default(cuid())
  companyId          String
  customerId         String
  riskAnalysisId     String
  score              Int?
  riskLevel          CustomerRiskLevel         @default(NOT_CLASSIFIED)
  approvedSalesLimit Decimal?                  @db.Decimal(12, 2)
  finalOpinion       CustomerRiskFinalOpinion?
  source             CustomerRiskHistorySource @default(INTERNAL_REVIEW)
  notes              String?
  createdById        String?
  company            Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer           Customer                  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  riskAnalysis       CustomerRiskAnalysis      @relation(fields: [riskAnalysisId], references: [id], onDelete: Cascade)
  createdBy          User?                     @relation("CustomerRiskHistoryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt          DateTime                  @default(now())

  @@index([companyId, customerId, createdAt])
  @@index([riskAnalysisId, createdAt])
}

model CustomerRiskExternalQuery {
  id             String                     @id @default(cuid())
  companyId      String
  customerId     String
  riskAnalysisId String
  sourceType     CustomerRiskExternalSource
  queryDate      DateTime?
  queryStatus    CustomerRiskQueryStatus    @default(NOT_ENABLED)
  summaryResult  String?
  rawReference   String?
  requestedById  String?
  company        Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer       Customer                   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  riskAnalysis   CustomerRiskAnalysis       @relation(fields: [riskAnalysisId], references: [id], onDelete: Cascade)
  requestedBy    User?                      @relation("CustomerRiskQueryRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)
  createdAt      DateTime                   @default(now())

  @@index([companyId, customerId, sourceType])
  @@index([riskAnalysisId, createdAt])
}

model CustomerRiskEvent {
  id             String                @id @default(cuid())
  companyId      String
  customerId     String
  riskAnalysisId String
  eventType      CustomerRiskEventType
  description    String
  scoreImpact    Int                   @default(0)
  notes          String?
  createdById    String?
  company        Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer       Customer              @relation(fields: [customerId], references: [id], onDelete: Cascade)
  riskAnalysis   CustomerRiskAnalysis  @relation(fields: [riskAnalysisId], references: [id], onDelete: Cascade)
  createdBy      User?                 @relation("CustomerRiskEventCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime              @default(now())

  @@index([companyId, customerId, createdAt])
  @@index([riskAnalysisId, createdAt])
}

model CustomerCertificate {
  id                String                       @id @default(cuid())
  companyId         String
  customerId        String
  certificateType   String?
  issuingAgency     String?
  status            CustomerCertificateStatus    @default(PENDING_PROCESSING)
  detectedSituation CustomerCertificateSituation @default(UNKNOWN)
  issueDate         DateTime?
  expirationDate    DateTime?
  fileName          String?
  fileUrl           String?
  extractedText     String?                      @db.Text
  uploadSource      CertificateUploadSource      @default(EXTERNAL)
  uploadedByUserId  String?
  uploadedAt        DateTime                     @default(now())
  validatedByUserId String?
  validatedAt       DateTime?
  notes             String?                      @db.Text
  company           Company                      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer          Customer                     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  uploadedByUser    User?                        @relation("CustomerCertificateUploadedBy", fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  validatedByUser   User?                        @relation("CustomerCertificateValidatedBy", fields: [validatedByUserId], references: [id], onDelete: SetNull)
  processingLogs    CertificateProcessingLog[]
  createdAt         DateTime                     @default(now())
  updatedAt         DateTime                     @updatedAt

  @@index([companyId, customerId, status])
  @@index([customerId, uploadedAt])
}

model CertificateUploadLink {
  id              String                      @id @default(cuid())
  companyId       String
  customerId      String
  token           String                      @unique
  status          CertificateUploadLinkStatus @default(ACTIVE)
  expiresAt       DateTime
  maxUploads      Int                         @default(5)
  uploadsUsed     Int                         @default(0)
  createdByUserId String?
  createdAt       DateTime                    @default(now())
  revokedAt       DateTime?
  company         Company                     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer        Customer                    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdByUser   User?                       @relation("CertificateUploadLinkCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([companyId, customerId, status])
  @@index([token, status])
}

model CertificateProcessingLog {
  id                      String                       @id @default(cuid())
  companyId               String
  customerCertificateId   String
  processStatus           CertificateProcessingStatus
  extractedType           String?
  extractedIssueDate      DateTime?
  extractedExpirationDate DateTime?
  extractedSituation      CustomerCertificateSituation @default(UNKNOWN)
  confidenceLevel         CertificateConfidenceLevel   @default(LOW)
  company                 Company                      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customerCertificate     CustomerCertificate          @relation(fields: [customerCertificateId], references: [id], onDelete: Cascade)
  createdAt               DateTime                     @default(now())

  @@index([companyId, createdAt])
  @@index([customerCertificateId, createdAt])
}

model UserCompany {
  id              String        @id @default(cuid())
  userId          String
  companyId       String
  accessProfileId String
  isPrimary       Boolean       @default(false)
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  accessProfile   AccessProfile @relation(fields: [accessProfileId], references: [id], onDelete: Restrict)
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([companyId, isActive])
  @@index([userId, isActive])
}

model AccessProfile {
  id                       String                    @id @default(cuid())
  code                     String                    @unique
  companyId                String?
  name                     String
  description              String?
  level                    AccessLevel               @default(ANALYST)
  tier                     AccessProfileTier         @default(BASIC)
  status                   EntityStatus              @default(ACTIVE)
  sequenceNumber           Int                       @default(0)
  isAdministrator          Boolean                   @default(false)
  isSystem                 Boolean                   @default(true)
  createdByUserId          String?
  updatedByUserId          String?
  userCompanies            UserCompany[]
  accessProfilePermissions AccessProfilePermission[]
  company                  Company?                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdByUser            User?                     @relation("AccessProfileCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser            User?                     @relation("AccessProfileUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt

  @@unique([companyId, sequenceNumber])
  @@index([companyId, status])
}

model PermissionResource {
  id                       String                    @id @default(cuid())
  code                     String                    @unique
  name                     String
  description              String?
  area                     String?
  module                   String?
  parentCode               String?
  route                    String?
  sortOrder                Int                       @default(0)
  isMenuVisible            Boolean                   @default(false)
  accessProfilePermissions AccessProfilePermission[]
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
}

model AccessProfilePermission {
  id                   String             @id @default(cuid())
  accessProfileId      String
  permissionResourceId String
  canView              Boolean            @default(false)
  canEdit              Boolean            @default(false)
  canCreate            Boolean            @default(false)
  canDelete            Boolean            @default(false)
  canManage            Boolean            @default(false)
  accessProfile        AccessProfile      @relation(fields: [accessProfileId], references: [id], onDelete: Cascade)
  permissionResource   PermissionResource @relation(fields: [permissionResourceId], references: [id], onDelete: Cascade)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@unique([accessProfileId, permissionResourceId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model GovernmentCertificate {
  id          String                      @id @default(cuid())
  companyId   String
  name        String
  expiresAt   DateTime?
  status      GovernmentCertificateStatus @default(NEGATIVE)
  pdfFileName String?
  company     Company                     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt   DateTime                    @default(now())
  updatedAt   DateTime                    @updatedAt

  @@unique([companyId, name])
  @@index([companyId, status])
}
